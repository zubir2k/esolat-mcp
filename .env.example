# esolat-mcp Environment Configuration
# Copy this file to .env and fill in your values.

# Required: Set a strong random secret for HTTP webhook authentication.
# The server will refuse to start in HTTP mode if this is missing or still set to the default.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_WEBHOOK_TOKEN=

# Port the server listens on (default: 8626)
PORT=8626

# Transport mode: stdio (default, for uvx/Claude Desktop) or http (for self-hosted Docker)
MCP_TRANSPORT=http

# ⚠️  NETWORK BINDING WARNING
# The server binds to 0.0.0.0 by default to allow cross-device LAN access
# (e.g. a device on 192.168.0.50 connecting to this server on 192.168.0.179).
# This is intentional for local LAN use.
#
# DO NOT expose port 8626 to the internet via port forwarding or public cloud deployment
# without adding a TLS-terminating reverse proxy (Nginx/Caddy) in front of it.
